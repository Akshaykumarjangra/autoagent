# ============================================
# Autonomix Global Swarm - Environment Config
# ============================================
# Copy this to .env.local and fill in your values

# --- Server ---
API_BACKEND_HOST=127.0.0.1
API_BACKEND_PORT=5000
API_PAYLOAD_MAX_SIZE=7mb
NODE_ENV=production

# --- Google Cloud / Vertex AI ---
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_PROJECT=your-gcloud-project-id

# --- Gemini API (used for agent services) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# --- Admin Auth ---
ADMIN_EMAIL=your-admin-email@gmail.com
JWT_SECRET=generate-a-strong-random-string-here

# --- Proxy Header (auto-generated, change if needed) ---
PROXY_HEADER=_8_CwigAIMyMXGlKVgxuNz3CztHpm7NC
